{
  "name": "strapi-localize",
  "version": "1.0.0",
  "description": "Strapi v5 plugin for automatic content translation using DeepL API",
  "keywords": [
    "strapi",
    "plugin",
    "strapi-plugin",
    "deepl",
    "translation",
    "i18n",
    "localization",
    "strapi-v5"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.js",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/src/index.js",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "axios": "^1.6.0",
    "react-intl": "^7.1.13"
  },
  "devDependencies": {
    "@strapi/strapi": "^5.27.0",
    "@strapi/sdk-plugin": "^5.3.2",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "styled-components": "^6.1.19"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.0.0",
    "@strapi/sdk-plugin": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-localize",
    "displayName": "Strapi Localize",
    "description": "Automatic content translation with DeepL"
  },
  "author": {
    "name": "Thomas Peroutka",
    "email": "perotom@github.com",
    "url": "https://github.com/perotom"
  },
  "maintainers": [
    {
      "name": "Thomas Peroutka",
      "email": "perotom@github.com",
      "url": "https://github.com/perotom"
    }
  ],
  "homepage": "https://github.com/perotom/strapi-localize",
  "bugs": {
    "url": "https://github.com/perotom/strapi-localize/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/perotom/strapi-localize.git"
  },
  "engines": {
    "node": ">=18.0.0 <=20.x.x",
    "npm": ">=6.0.0"
  },
  "license": "MIT"
}
